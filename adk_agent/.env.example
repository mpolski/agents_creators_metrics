# --- GCP Project IDs ---
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_GENAI_USE_VERTEXAI=1
TARGET_SA_EMAIL=

# --- MCP Toolset Configurations ---
# Add your local or remote MCP server endpoint here
MCP_ENDPOINT=https://bigquery.googleapis.com/mcp

# --- Global Context (BigQuery Defaults) ---
